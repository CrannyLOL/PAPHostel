{
  "version": 2,
  "buildCommand": "npm install",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "express",
  "public": true,
  "functions": {
    "server/index.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/(?!api).*\\.(html|css|js|json|png|jpg|jpeg|gif|svg|mp4|webp|woff|woff2|ttf)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(?!api)(.*)$",
      "dest": "/public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
